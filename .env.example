# Copy this file to ".env" in the same folder as app.py, then fill in values.
# The real ".env" file is gitignored and will not appear in the repository.
#
# Render.com: do NOT rely on .env in the repo. In the service → Environment:
#   Add OPENAI_API_KEY (Secret) and optionally OPENAI_MODEL, MODEL_PROVIDER=openai
#   Save, then Manual Deploy → Clear build cache & deploy (or redeploy) so the app restarts.

# Optional: force provider — "openai" | "bedrock" (otherwise inferred from keys)
# MODEL_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Amazon Bedrock (alternative to OpenAI) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
